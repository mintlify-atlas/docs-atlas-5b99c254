        "pages": [
          "introduction",
          "quickstart",
          "installation"
        ]
      },
      {
        "group": "Features",
        "pages": [
          "features/live-streaming",
          "features/chat-system",
          "features/countdown-timer",
          "features/gallery",
          "features/event-timeline"
        ]
      },
      {
        "group": "Customization",
        "pages": [
          "customization/colors-and-branding",
