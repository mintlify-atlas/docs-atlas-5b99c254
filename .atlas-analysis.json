{
  "projectType": "frontend",
  "projectName": "Mikunki Shapshico",
  "projectDescription": "A festival website featuring live streaming, interactive chat, and event management for the UNHEVAL gastronomic and cultural festival in Huánuco, Peru.",
  "theme": "almond",
  "primaryColor": "#CC0000",
  "lightColor": "#FF6600",
