  },
  "keyFeatures": [
    "Live streaming integration with Vimeo player",
    "Twitch-style chat system with user registration and superchats",
    "Real-time countdown timer to festival date",
    "Interactive photo gallery with lightbox",
    "Event timeline with schedule information",
    "Particle effects and parallax animations",
    "Mobile-responsive design",
    "Social sharing functionality"
  ],
  "publicApiSurface": [
    "CONFIG.STREAM_URL - Live stream URL configuration",
    "CONFIG.IS_LIVE - Toggle live stream status",
    "CONFIG.FESTIVAL_DATE - Festival date for countdown",
    "CONFIG.PARTICLE_COUNT - Particle effect density",
    "initParticles() - Initialize floating particles",
    "initNavigation() - Setup navigation and menu",
    "initCountdown() - Initialize countdown timer",
    "initLiveStream() - Setup live streaming player",
    "initChat() - Initialize chat system",
    "initLightbox() - Setup gallery lightbox",
    "CSS Variables: --red-main, --fire-1, --gold, etc."
  ]
}
